# CloudSentinel dashboard Jenkins integration
# Base Jenkins URL, e.g. http://43.205.130.141:8080
JENKINS_BASE_URL=

# Jenkins pipeline job name. For folder jobs, use slash format (folder1/folder2/job)
JENKINS_JOB_NAME=

# Jenkins API credentials (username + user API token)
JENKINS_USERNAME=
JENKINS_API_TOKEN=

# Optional: number of recent builds to show in dashboard history
JENKINS_HISTORY_LIMIT=8
